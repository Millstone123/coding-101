{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "validate-environment",
      "type": "shell",
      "command": "npm run check:env",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "dev",
      "type": "shell",
      "command": "npm run dev",
      "dependsOn": ["validate-environment"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
